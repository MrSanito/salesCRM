// Trigger reload - SaaS Multi-tenant Schema
generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ORG_ADMIN
  MANAGER
  SALES_REP
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  CLOSED_LOST
}

enum InteractionType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  IN_PERSON
}

enum ReminderType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
}

enum ReminderStatus {
  PENDING
  DONE
  SNOOZED
  CANCELLED
}

enum AlertType {
  FOLLOW_UP_DUE
  LEAD_ASSIGNED
  STAGE_CHANGED
  REMINDER_DUE
  AI_REMINDER
  SYSTEM
}

enum AttachmentMimeType {
  PDF // application/pdf  ← primary use-case
  DOCX // application/vnd.openxmlformats-officedocument.wordprocessingml.document
  XLSX // application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
  PNG // image/png
  JPEG // image/jpeg
  OTHER
}

// ─────────────────────────────────────────────────────────────
// MULTI-TENANT (SaaS)
// ─────────────────────────────────────────────────────────────

model Organization {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  logoUrl String?

  users        User[]
  teams        Team[]
  leads        Lead[]
  sources      LeadSource[]
  stages       PipelineStage[]
  interactions Interaction[]
  notes        Note[]
  reminders    Reminder[]
  alerts       Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────
// USER & TEAM
// ─────────────────────────────────────────────────────────────

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  initials String @db.VarChar(4)

  role      Role    @default(SALES_REP)
  avatarUrl String?

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Self-referential: manager → subordinates
  managerId    String?
  manager      User?   @relation("UserHierarchy", fields: [managerId], references: [id])
  subordinates User[]  @relation("UserHierarchy")

  // Team membership
  teamId String?
  team   Team?   @relation("TeamMembers", fields: [teamId], references: [id])

  // Team that this user manages (one user = one managed team)
  managedTeam Team? @relation("TeamManager")

  // Leads
  ownedLeads   Lead[] @relation("LeadOwner")
  createdLeads Lead[] @relation("LeadCreator")

  // Activity
  interactions Interaction[]
  notes        Note[]
  reminders    Reminder[]
  alerts       Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("users")
}

model Team {
  id   String @id @default(uuid())
  name String

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // The user who manages this team
  managerId String @unique
  manager   User   @relation("TeamManager", fields: [managerId], references: [id])

  // Members of this team
  members User[] @relation("TeamMembers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("teams")
}

// ─────────────────────────────────────────────────────────────
// LEAD SOURCE & PIPELINE
// ─────────────────────────────────────────────────────────────

model LeadSource {
  id   String @id @default(uuid())
  name String

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  leads Lead[]

  @@unique([name, organizationId])
  @@map("lead_sources")
}

model PipelineStage {
  id          String  @id @default(uuid())
  name        String
  orderIndex  Int
  colorClass  String
  description String?

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  leads Lead[]

  @@unique([name, organizationId])
  @@unique([orderIndex, organizationId])
  @@map("pipeline_stages")
}

// ─────────────────────────────────────────────────────────────
// LEAD  (core business entity)
// ─────────────────────────────────────────────────────────────

model Lead {
  id          String  @id @default(uuid())
  contactName String
  company     String
  email       String?
  phone       String?

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Stage & value
  stage        LeadStage    @default(NEW)
  dealValueInr Decimal      @default(0) @db.Decimal(15, 2)
  priority     LeadPriority @default(MEDIUM)

  // Relations to ref tables
  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])

  sourceId String?
  source   LeadSource? @relation(fields: [sourceId], references: [id])

  // Ownership
  ownerId     String
  owner       User   @relation("LeadOwner", fields: [ownerId], references: [id])
  createdById String
  createdBy   User   @relation("LeadCreator", fields: [createdById], references: [id])

  // Timestamps
  followUpAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Child records
  interactions Interaction[]
  notes        Note[]
  reminders    Reminder[]
  alerts       Alert[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([stage])
  @@index([priority])
  @@index([followUpAt])
  @@map("leads")
}

// ─────────────────────────────────────────────────────────────
// INTERACTION  (every contact with a lead must be recorded)
// ─────────────────────────────────────────────────────────────

model Interaction {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  type        InteractionType
  summary     String?
  durationMin Int?
  occurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())

  note Note? @relation("InteractionNote")

  @@index([organizationId])
  @@index([leadId])
  @@index([userId])
  @@index([occurredAt])
  @@map("interactions")
}

// ─────────────────────────────────────────────────────────────
// NOTE
//   • Can live on an Interaction (interactionId set)   ← "interaction note"
//   • Can live directly on a Lead (interactionId null) ← "standalone lead note"
//   A Lead therefore has MANY notes in total.
//   PDF attachments are stored in NoteAttachment.
// ─────────────────────────────────────────────────────────────

model Note {
  id String @id @default(uuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  interactionId String?      @unique
  interaction   Interaction? @relation("InteractionNote", fields: [interactionId], references: [id], onDelete: SetNull)

  content     String  @db.Text
  aiExtracted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments NoteAttachment[]

  @@index([organizationId])
  @@index([leadId])
  @@index([interactionId])
  @@map("notes")
}

// ─────────────────────────────────────────────────────────────
// NOTE ATTACHMENT  (PDFs and other files on a note)
// ─────────────────────────────────────────────────────────────

model NoteAttachment {
  id String @id @default(uuid())

  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  fileName      String // original file name, e.g. "proposal_v2.pdf"
  fileUrl       String // storage URL (S3 / Supabase / Cloudflare R2)
  fileKey       String // storage key / path for deletion
  fileSizeBytes Int // raw byte size
  mimeType      AttachmentMimeType @default(PDF)
  pageCount     Int? // populated for PDFs after upload processing

  uploadedAt DateTime @default(now())

  @@index([noteId])
  @@map("note_attachments")
}

// ─────────────────────────────────────────────────────────────
// REMINDER
// ─────────────────────────────────────────────────────────────

model Reminder {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  type        ReminderType
  status      ReminderStatus @default(PENDING)
  aiExtracted Boolean        @default(false)
  scheduledAt DateTime
  completedAt DateTime?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([userId, scheduledAt])
  @@index([leadId])
  @@map("reminders")
}

// ─────────────────────────────────────────────────────────────
// ALERT
// ─────────────────────────────────────────────────────────────

model Alert {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SaaS Isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  type   AlertType
  title  String
  body   String?
  isRead Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([userId, isRead])
  @@map("alerts")
}
